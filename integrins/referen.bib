@article{2004_Morten,
   abstract = {A topical review of the current state of lipid-protein interactions is given with focus on the physical interactions between lipids and integral proteins in lipid-bilayer membranes. The concepts of hydrophobic matching and curvature stress are revisited in light of recent data obtained from experimental and theoretical studies which demonstrate that not only do integral proteins perturb the lipids, but the physical state of the lipids does also actively influence protein function. The case of the trans-membrane water-channel protein aquaporin GlpF from E. coli imbedded in lipid-bilayer membranes is discussed in some detail. Numerical data obtained from Molecular Dynamics simulations show on the one side that the lipid bilayer adapts to the channel by a hydrophobic matching condition which reflects the propensity of the lipid molecules for forming curved structures. On the other side, it is demonstrated that the transport function of the channel is modulated by the matching condition and/or the curvature stress in a lipid-specific manner. © 2004 Elsevier B.V. All rights reserved.},
   author = {$\Theta$ Jensen Morten and Ole G. Mouritsen},
   doi = {10.1016/j.bbamem.2004.06.009},
   issn = {00052736},
   issue = {1-2},
   journal = {Biochim. Biophys. Acta},
   keywords = {Curvature stress,Gramicidin A,Hydrophobic matching,Hydrophobic thickness,Integral membrane protein,Lipid bilayer,Lipid domain,Membrane raft,Protein folding,Protein insertion,Structure-function relationship,Trans-membrane peptide},
   month = {11},
   pages = {205-226},
   pmid = {15519316},
   title = {Lipids do influence protein function - The hydrophobic matching hypothesis revisited},
   volume = {1666},
   year = {2004}
}
